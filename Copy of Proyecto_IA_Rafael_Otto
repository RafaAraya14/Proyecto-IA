le_size, tile_size)).convert(\"RGB\"))\n","tile_mask = mask[y:y+tile_size, x:x+tile_size]\n","\n","\n","print(\"Coordenadas:\", x, y)\n","print(\"Slide tile:\", tile_slide.shape)\n","print(\"Mask tile:\", tile_mask.shape)\n","\n","#se muestran los resultados obtenidos del slide y su marca cirrespondiente\n","fig, axes = plt.subplots(1, 2, figsize=(12, 6))\n","axes[0].imshow(tile_slide)\n","axes[0].set_title(\"Tile del slide\")\n","axes[0].axis(\"off\")\n","\n","axes[1].imshow(tile_mask, cmap=\"gray\")\n","axes[1].set_title(\"Tile de la máscara\")\n","axes[1].axis(\"off\")\n","\n","plt.tight_layout()\n","plt.show()\n","\n","fin = time.time()\n","print(f\"Tiempo de ejecución: {fin - inicio:.4f} segundos\")"]},{"cell_type":"markdown","metadata":{"id":"a917c01d"},"source":["### 9. Generación del Manifiesto de Tiles (Filtrado de Tejido)"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"OH2jJSdC21r8","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1780250728790,"user_tz":360,"elapsed":26808,"user":{"displayName":"Rafael Araya","userId":"08247490411257317849"}},"outputId":"45265741-133c-4912-f950-abf9e48ee803"},"outputs":[{"output_type":"stream","name":"stdout","text":["[1/10] Procesando imagen: 00a26aaa82c959624d90dfb69fcf259c...\n","  -> Tile 1 guardado en (x=0, y=0)\n","  -> Tile 2 guardado en (x=512, y=0)\n","  -> Tile 3 guardado en (x=1024, y=0)\n","  -> Tile 4 guardado en (x=1536, y=0)\n","  -> Tile 5 guardado en (x=2048, y=0)\n","  -> Tile 6 guardado en (x=2560, y=0)\n","  -> Tile 7 guardado en (x=3072, y=0)\n","  -> Tile 8 guardado en (x=3584, y=0)\n","  -> Tile 9 guardado en (x=4096, y=0)\n","  -> Tile 10 guardado en (x=4608, y=0)\n","  -> Tile 11 guardado en (x=5120, y=0)\n","  -> Tile 12 guardado en (x=5632, y=0)\n","  -> Tile 13 guardado en (x=6144, y=0)\n","  -> Tile 14 guardado en (x=6656, y=0)\n","  -> Tile 15 guardado en (x=7168, y=0)\n","  -> Tile 16 guardado en (x=7680, y=0)\n","  -> Tile 17 guardado